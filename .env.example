# APP_ENV separates local, staging, and production behavior.
# Use local for developer machines. Use staging and production with separate databases,
# OAuth clients, provider keys, and secret stores. Placeholder values below are local-only.
APP_ENV="local"

DATABASE_URL="postgresql://xuyenviet:xuyenviet@localhost:5432/xuyenviet"
# Dedicated local archive database for `facebook:capture` and `youtube:capture` only.
# It must never equal DATABASE_URL and is migrated only with `pnpm capture-cache:migrate`.
CAPTURE_CACHE_DATABASE_URL="postgresql://xuyenviet:xuyenviet@localhost:5432/xuyenviet_capture_cache"
# Integration tests use a separate database. Never point this at dev or production.
DATABASE_URL_TEST="postgresql://xuyenviet:xuyenviet@localhost:5432/xuyenviet_test"
AUTH_SECRET="replace-with-local-development-secret"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"
# Optional: Google account email that receives admin and operator roles on login.
ADMIN_EMAIL=""
# Local Google OAuth callback: http://localhost:3000/api/auth/callback/google
# Set AUTH_URL per deployed environment, for example: https://staging.xuyenviet.example
# Production must use real non-placeholder values for all variables above.
AI_GATEWAY_BASE_URL="replace-with-openai-compatible-ai-gateway-url"
AI_GATEWAY_API_KEY="replace-with-ai-gateway-api-key"
# Used exclusively by the server-run `pnpm youtube:capture` operations script.
# Never expose this key to browser code, request-serving routes, logs, or audit records.
GEMINI_API_KEY="replace-with-gemini-api-key"
# Optional YouTube Data API key used only to read public video durations. Falls back to GEMINI_API_KEY when omitted.
YOUTUBE_DATA_API_KEY=""
# Optional model used only by youtube:capture.
GEMINI_YOUTUBE_MODEL="gemini-3.5-flash"
# Optional media resolution used only by youtube:capture. Defaults to low when omitted.
GEMINI_YOUTUBE_MEDIA_RESOLUTION="MEDIA_RESOLUTION_LOW"
# Optional Gateway request timeout in milliseconds. Values are clamped between 1000 and 180000; default is 30000.
AI_GATEWAY_TIMEOUT_MS="30000"
# Optional extraction-specific timeout for long-running worker calls; falls back to AI_GATEWAY_TIMEOUT_MS.
AI_GATEWAY_EXTRACTION_TIMEOUT_MS="90000"
# Optional worker loop controls.
KNOWLEDGE_EXTRACTION_WORKER_POLL_MS="5000"
KNOWLEDGE_EXTRACTION_WORKER_STALE_MS="900000"
TAVILY_API_KEY="replace-with-tavily-api-key"
# Facebook capture pacing defaults: 12-25 seconds between attempts and 1 minute after every 10 attempts.
FACEBOOK_CAPTURE_DELAY_MIN_MS="12000"
FACEBOOK_CAPTURE_DELAY_MAX_MS="25000"
FACEBOOK_CAPTURE_BATCH_SIZE="10"
FACEBOOK_CAPTURE_BATCH_COOLDOWN_MS="60000"
